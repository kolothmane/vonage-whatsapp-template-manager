generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Operator
  Viewer
}

enum WabaStatus {
  Connected
  Syncing
  ActionRequired
}

enum SupportedBrand {
  AB
  AD
  BNT
  CH
  CLB
}

enum SupportedLanguage {
  EN
  FR
  ES
  PT
  IT
  DE
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  Pending
  Submitted
  Approved
  Rejected
  Failed
  Skipped
}

enum ImportMode {
  STRICT
  RELAXED
}

enum ImportStatus {
  Queued
  Validating
  Blocked
  Processing
  Completed
  Failed
}

enum AuditAction {
  Create
  Update
  Delete
  Submit
  Retry
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(Viewer)
  sessions     Session[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model Waba {
  id            String     @id
  name          String
  status        WabaStatus @default(Connected)
  country       String
  templateCount Int        @default(0)
  lastSyncAt    DateTime?
  templates     Template[]
  imports       Import[]
  logs          Log[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("wabas")
}

model Template {
  id             String            @id @default(cuid())
  wabaId         String
  waba           Waba              @relation(fields: [wabaId], references: [id], onDelete: Cascade)
  brand          SupportedBrand
  language       SupportedLanguage
  whatsappLang   String
  originalName   String
  generatedName  String
  body           String
  category       TemplateCategory
  automation     String
  status         TemplateStatus    @default(Pending)
  versions       TemplateVersion[]
  variableMaps   VariableMapping[]
  importItems    ImportItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([wabaId, generatedName])
  @@index([brand, language])
  @@index([status])
  @@map("templates")
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    Int
  payload    Json
  createdAt  DateTime @default(now())

  @@unique([templateId, version])
  @@map("template_versions")
}

model Import {
  id         String       @id @default(cuid())
  wabaId     String?
  waba       Waba?        @relation(fields: [wabaId], references: [id], onDelete: SetNull)
  fileName   String
  target     String
  mode       ImportMode   @default(STRICT)
  status     ImportStatus @default(Queued)
  total      Int          @default(0)
  submitted  Int          @default(0)
  failed     Int          @default(0)
  skipped    Int          @default(0)
  duplicates Int          @default(0)
  items      ImportItem[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([status, createdAt])
  @@map("imports")
}

model ImportItem {
  id           String         @id @default(cuid())
  importId     String
  import       Import         @relation(fields: [importId], references: [id], onDelete: Cascade)
  templateId   String?
  template     Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  generatedName String
  brand        SupportedBrand
  language     SupportedLanguage
  payload      Json
  response     Json?
  error        String?
  status       TemplateStatus @default(Pending)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([importId, status])
  @@map("import_items")
}

model Log {
  id           String            @id @default(cuid())
  importId     String?
  wabaId       String?
  waba         Waba?             @relation(fields: [wabaId], references: [id], onDelete: SetNull)
  templateName String
  brand        SupportedBrand
  language     SupportedLanguage
  status       TemplateStatus
  payload      Json?
  response     Json?
  error        String?
  message      String
  timestamp    DateTime          @default(now())

  @@index([timestamp])
  @@index([wabaId])
  @@map("logs")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail String
  action    AuditAction
  entity    String
  oldValue  String?
  newValue  String?
  date      DateTime    @default(now())

  @@index([date])
  @@map("audit_logs")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model VariableMapping {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  placeholder String
  key        String
  source     String
  createdAt  DateTime @default(now())

  @@index([templateId])
  @@map("variable_mappings")
}
